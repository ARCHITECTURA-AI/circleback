# Circle Back — Local Development Environment
# Copy this to .env and fill in your values

DATABASE_URL=postgresql+asyncpg://circleback:circleback_dev@localhost:5432/circleback

# Anthropic API Key (get from https://console.anthropic.com/)
# Only needed if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Groq API Key (get from https://console.groq.com/keys)
# Default provider — set this for Groq LLM calls
GROQ_API_KEY=

# LLM Provider: 'groq' (default) or 'anthropic'
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Slack OAuth (get from Slack API dashboard)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Token encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
TOKEN_ENCRYPTION_KEY=

# Session auth secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET_KEY=

# URLs (set these for production — defaults work for local dev)
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# App settings
DEBUG=true
LOG_LEVEL=DEBUG
LLM_DAILY_COST_LIMIT_USD=1.0
AT_RISK_HOURS_BEFORE_DEADLINE=24
